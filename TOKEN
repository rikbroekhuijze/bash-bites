#!/bin/bash

VERSION="0.11"
MYBASENAME=$(basename "$0")

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <n> [<delimiter>]

Extracts the n-th token from a text string.
Tokens are separated by delimiter (default: space).

Parameters:
  text        - The string to extract from (can be passed via pipe)
  n           - Token number to extract:
                 positive: count from the start (1 = first token)
                 negative: count from the end (-1 = last token)
                 0 is invalid
  delimiter   - Optional: character(s) that separate tokens (default: space)

Examples:
  $MYBASENAME "one two three four five" 3       # -> three
  $MYBASENAME "one two three four five" -1      # -> five (last token)
  $MYBASENAME "one two three four five" -2      # -> four (second last)
  echo "one,two,three,four,five" | $MYBASENAME -2 ','
  $MYBASENAME "one--two--three" 2 "--"          # Multi-char delimiter
  $MYBASENAME "--test--" 1 "--"                  # Delimiter that looks like an option
  
  # Extract third line from multi-line text
  echo "line one
line two
line three
line four" | $MYBASENAME -2 $'\n'               # -> line three

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

TOKEN() {
    
    local haystack="$1"
    local n="$2"
    local delimiter="$3"
    
    # Als delimiter niet is meegegeven, gebruik spatie
    if [ -z "$delimiter" ]; then
        delimiter=" "
    fi
    
    # Validatie: n moet een getal zijn en mag niet 0 zijn
    if [[ ! "$n" =~ ^-?[0-9]+$ ]] || [ "$n" -eq 0 ]; then
        echo "ERROR: n must be a non-zero integer" >&2
        return 1
    fi
    
    # Split de string op delimiter
    local tokens=()
    
    if [ "$delimiter" = $'\n' ]; then
        # Split op newline met mapfile
        mapfile -t tokens <<< "$haystack"
        
        # Als de haystack eindigt met een newline, verwijder lege token
        if [ "${#tokens[@]}" -gt 0 ] && [ -z "${tokens[${#tokens[@]}-1]}" ] && [[ "$haystack" == *$'\n' ]]; then
            unset 'tokens[${#tokens[@]}-1]'
        fi
    else
        # Vervang delimiter door een uniek controleteken
        local unique_delim=$'\001'
        local processed=$(echo "$haystack" | sed "s|$delimiter|$unique_delim|g")
        IFS="$unique_delim" read -ra tokens <<< "$processed"
    fi
    
    # Bereken de effectieve index
    local index
    if [ "$n" -gt 0 ]; then
        index=$((n - 1))
    else
        index=$((${#tokens[@]} + n))
    fi
    
    # Check of token bestaat
    if [ "$index" -lt 0 ] || [ "$index" -ge "${#tokens[@]}" ]; then
        return 1
    fi
    
    # Alleen echoën als token niet leeg is
    if [ -n "${tokens[index]}" ]; then
        echo "${tokens[index]}"
    fi
}

# MAIN 
args=()

# Check voor pipe input
if [ ! -t 0 ]; then
    # Lees ALLE stdin met de nieuwe methode (behoudt newlines!)
    stdin_content=$(cat; echo bla)
    stdin_content="${stdin_content::-4}"
    if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    fi
fi

# Voeg command line argumenten toe, maar behandel -- speciaal
for arg in "$@"; do
    case "$arg" in
        -h|--help)
        
            show_usage
            exit 0
            ;;
        -v|--version)
            echo "$VERSION"
            exit 0
            ;;
       
        *)
            args+=("$arg")
            ;;
    esac
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "ERROR: Need at least text and token number" >&2
    show_usage
    exit 1
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "ERROR: Too many arguments" >&2
    show_usage
    exit 1
fi

# Debug: toon args (uitcommentarieer voor testen)
# echo "args: ${#args[@]}" >&2
# for i in "${!args[@]}"; do
#     echo "  $i: '${args[i]}'" >&2
# done

# Roep TOKEN aan
TOKEN "${args[@]}"
exit $?
