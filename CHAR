#!/bin/bash

VERSION="0.2"
MYBASENAME=$(basename "$0")

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <start> [<end>]

Returns character(s) at specified position(s).

Parameters:
  text        - The string to extract from (can be passed via pipe)
  start       - Position to start (1 = first, -1 = last)
  end         - Optional: end position (inclusive)

Examples:
  $MYBASENAME "hello" 2           # -> e
  $MYBASENAME "hello" -1          # -> o
  $MYBASENAME "hello" 2 4         # -> e l l  (or "ell"?)
  $MYBASENAME "hello" 2 -1        # -> e l l o (2 to last)
  $MYBASENAME "hello" -3 -1       # -> l l o (last three)

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

CHAR() {
    local string="$1"
    local start="$2"
    local end="${3:-$2}"
    local len=${#string}
    
    
   #   echo "DEBUG: len=$len" >&2
   #   echo "DEBUG: string als bytes:" >&2
   #   for ((i=0; i<len; i++)); do
   #       char="${string:$i:1}"
   #       printf "  %d: '%s' (ASCII %d)\n" $((i+1)) "$char" "'$char" >&2
   #   done
    
    # Validatie
    if [[ ! "$start" =~ ^-?[0-9]+$ ]] || [[ ! "$end" =~ ^-?[0-9]+$ ]]; then
        echo "ERROR: Positions must be integers" >&2
        return 1
    fi
    
    # Converteer naar 0-based indices
    if [ "$start" -gt 0 ]; then
        start=$((start - 1))
    elif [ "$start" -lt 0 ]; then
        start=$((len + start))
    fi
    
    if [ "$end" -gt 0 ]; then
        end=$((end - 1))
    elif [ "$end" -lt 0 ]; then
        end=$((len + end))
    fi
    
    # Zorg dat start <= end
    if [ "$start" -gt "$end" ]; then
        local tmp="$start"
        start="$end"
        end="$tmp"
    fi
    
    # Check of binnen bereik
    [ "$start" -lt 0 ] && start=0
    [ "$end" -ge "$len" ] && end=$((len - 1))
    
    # Extract karakters
    local result=""
    for ((i=start; i<=end; i++)); do
        result+="${string:$i:1}"
    done
    
    # Alleen output als resultaat niet leeg is
    if [ -n "$result" ]; then
        # Gebruik printf om extra newline te voorkomen
        printf "%s" "$result"
    fi
    
    
    
    # Extract karakters
  #   local result=""
 #    for ((i=start; i<=end; i++)); do
  #       result+="${string:$i:1}"
  #   done
    
  #   echo "DEBUG: result='$result'" >&2
  #   echo "DEBUG: result lengte=${#result}" >&2
    
    # Alleen output als resultaat niet leeg is
    if [ -n "$result" ]; then
        printf "%s" "$result"
    else
        echo "DEBUG: result is leeg!" >&2
    fi
    
    
}

# MAIN 
args=()

# Check voor pipe input
if [ ! -t 0 ]; then
    # Lees ALLE stdin met de nieuwe methode (behoudt newlines!)
    stdin_content=$(cat; echo bla)
    stdin_content="${stdin_content::-4}"
    if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    fi
fi

# Verwerk argumenten
for arg in "$@"; do
    case "$arg" in
        -h|--help) show_usage; exit 0 ;;
        -v|--version) echo "$VERSION"; exit 0 ;;
        *) args+=("$arg") ;;
    esac
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "ERROR: Need at least text and start position" >&2
    show_usage
    exit 1
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "ERROR: Too many arguments" >&2
    show_usage
    exit 1
fi

CHAR "${args[@]}"

# Alleen een newline als er output was
if [ $? -eq 0 ] && [ -n "$(CHAR "${args[@]}")" ]; then
    echo
fi

exit $?
